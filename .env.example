APP_NAME="Enrique Delgado — El Psicólogo del Cambio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://enriquedelgado.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Base de datos MySQL ──────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=enrique_delgado
DB_USERNAME=tu_usuario_bd
DB_PASSWORD=tu_password_bd

# ─── Session ─────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En producción (HTTPS) debe ser true. En local (http://localhost) dejar en false.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# El email del formulario de contacto se manda en segundo plano (no bloquea al usuario).
# Requiere un worker corriendo en el servidor: ver "Configurar el queue worker" en DEPLOY-PLESK.md.
QUEUE_CONNECTION=database

CACHE_STORE=file

# ─── Mail ─────────────────────────────────────────────
# El SMTP real (host, puerto, usuario, contraseña) se carga desde
# Admin > Configuración > Email una vez desplegado — pisa esto automáticamente.
# No hace falta tocar estas líneas: "log" es seguro mientras tanto, no pierde
# mensajes (siempre quedan en Admin > Consultas), solo no los manda por correo.
MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
